<Window x:Class="QuanLyShopGiay.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
        xmlns:helper="clr-namespace:QuanLyShopGiay.Helpers" 
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:LoginModelView/>
    </Window.DataContext>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Anh/bg_login.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.6">
                    <GradientStop Color="Black" Offset="1"/>
                    <GradientStop Color="#FF333333" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border CornerRadius="15"
                    Background="#EA1E1E1E"
                    Padding="30,20,30,25"
                    Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ĐĂNG NHẬP HỆ THỐNG" 
                               Grid.Row="0"
                               HorizontalAlignment="Center" 
                               FontWeight="Bold" 
                               Foreground="White"
                               FontSize="22" 
                               Margin="0,0,0,20"/>

                    <Label Content="Tên đăng nhập:" 
                           Grid.Row="1" 
                           Foreground="White"
                           FontSize="14" 
                           Margin="0,5,0,5"/>

                    <TextBox x:Name="txtUsername" 
                             Grid.Row="2"
                             Text="{Binding MaNV, UpdateSourceTrigger=PropertyChanged}" 
                             VerticalContentAlignment="Center"
                             Padding="5,0,5,0"
                             Height="35" 
                             FontSize="14"/>

                    <Label Content="Mật khẩu:" 
                           Grid.Row="3" 
                           Foreground="White"
                           FontSize="14" 
                           Margin="0,15,0,5"/>

                    <PasswordBox x:Name="txtPassword"  
                                 Grid.Row="4"
                                 helper:PasswordBoxHelper.BoundPassword="{Binding MatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 VerticalContentAlignment="Center"
                                 Padding="5,0,5,0"
                                 Height="35" 
                                 FontSize="14"/>

                    <Button Command="{Binding LoginCommand}" 
                            Content="Đăng Nhập" 
                            Grid.Row="5" 
                            HorizontalAlignment="Center" 
                            Cursor="Hand"
                            FontWeight="Bold"
                            Margin="0,25,0,0" 
                            Width="180" 
                            Height="38"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>