<Window x:Class="QuanLyShopGiay.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
        xmlns:helpers="clr-namespace:QuanLyShopGiay.Helpers"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Window.DataContext>
        <local:LoginViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Anh/bg_login.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.72">
                    <GradientStop Color="Black" Offset="1"/>
                    <GradientStop Color="#FF676767" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid>
                <Border CornerRadius="20"
                        Background="#CC1E1E1E"
                        Padding="20"
                        MinWidth="400"
                        MaxWidth="600"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center">

                        <TextBlock TextWrapping="Wrap" Text="Đăng nhập"
                                   Foreground="White" HorizontalAlignment="Center"
                                   FontSize="18" FontWeight="Bold" Margin="0,20,0,20"/>

                        <TextBlock TextWrapping="Wrap" Text="Tên đăng nhập:"
                                   Foreground="White" Margin="10,20,0,5"
                                   FontSize="14" FontWeight="Bold"/>

                        <!-- BINDING 2 chiều với LoginViewModel.TenDangNhap -->
                        <TextBox x:Name="txtNameUser"
                                 Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <TextBlock TextWrapping="Wrap" Text="Mật khẩu:"
                                   Foreground="White" Margin="10,20,0,5"
                                   FontSize="14" FontWeight="Bold"/>

                        <!-- PasswordBox giữ nguyên x:Name, code-behind wire-up qua Func<string> -->
                        <PasswordBox x:Name="txtPassword" 
                         helpers:PasswordBoxHelper.BoundPassword="{Binding MatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5"/>
                        <!-- THÊM DÒNG NÀY VÀO NGAY BÊN DƯỚI -->
                        <TextBox x:Name="txtPasswordVisible"
         Text="{Binding MatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         Margin="5"
         Visibility="Collapsed"/>
                        <!-- Hiển thị lỗi - tự ẩn khi ThongBaoLoi rỗng -->
                        <TextBlock Text="{Binding ThongBaoLoi}"
                                   Foreground="#FFFF5252" FontSize="13"
                                   TextWrapping="Wrap" Margin="10,4,10,0"
                                   Visibility="{Binding ThongBaoLoi,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,20">
                            <CheckBox x:Name="chkHienMatKhau"
          Content="Hiện mật khẩu"
          Foreground="White" Margin="5,10,0,0" FontSize="14"
          Checked="chkHienMatKhau_Checked"
          Unchecked="chkHienMatKhau_Unchecked"/>
                        </StackPanel>

                        <!-- COMMAND: ChuyenDangKyCommand thay MouseLeftButtonUp event -->
                        <TextBlock TextWrapping="Wrap"
           Text="Chưa có tài khoản hãy nhấn ở đây để đăng kí mới."
           Foreground="#FFF4B62F" Margin="20,-10,0,0"
           Cursor="Hand" FontSize="14" TextDecorations="Underline">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                      Command="{Binding ChuyenDangKyCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>

                        <!-- COMMAND: LoginCommand thay Click event -->
                        <!-- IsEnabled tự tắt khi DangXuLy=true nhờ CanExecute -->
                        <Button x:Name="BtnLogin" 
            Content="Đăng nhập"
        Command="{Binding LoginCommand}"
        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
        HorizontalAlignment="Center" 
        Width="200" 
        Margin="0,20,0,20"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
