<Page x:Class="QuanLyShopGiay.Views.Pages.KhoHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1000"
      Background="#FFF0F2F5"
      Title="KhoHangPage">

    <Page.DataContext>
        <local:KhoHangViewModel/>
    </Page.DataContext>

    <Grid Margin="24">
        <Border Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>

            <TabControl BorderThickness="0" Background="Transparent">

                <TabItem Header="📦 Tồn kho" FontSize="14">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="34" Padding="10,0" FontSize="13"
                                     VerticalContentAlignment="Center" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                     Text="{Binding SearchTextKho, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <ComboBox Grid.Column="2" Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                      DisplayMemberPath="TenKho" SelectedValuePath="MaKho"
                                      ItemsSource="{Binding ListFilterKho}" SelectedValue="{Binding SelectedMaKho, Mode=TwoWay}"/>

                            <ComboBox Grid.Column="4" Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                      DisplayMemberPath="TenNSX" SelectedValuePath="MaNSX"
                                      ItemsSource="{Binding ListFilterNSX}" SelectedValue="{Binding SelectedMaNSX, Mode=TwoWay}"/>
                        </Grid>

                        <DataGrid Grid.Row="1" x:Name="dgTonKho" AutoGenerateColumns="False" IsReadOnly="True" 
                                  ItemsSource="{Binding ListTonKho}" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#FFE0E0E0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kho" Binding="{Binding KHO.TenKho}" Width="150"/>
                                <DataGridTextColumn Header="Sản phẩm" Binding="{Binding BIEN_THE_SP.SAN_PHAM.TenSP}" Width="*"/>
                                <DataGridTextColumn Header="NSX" Binding="{Binding BIEN_THE_SP.SAN_PHAM.NHA_SAN_XUAT.TenNSX}" Width="140"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding BIEN_THE_SP.SIZE_GIAY.TenSize}" Width="80"/>
                                <DataGridTextColumn Header="Màu" Binding="{Binding BIEN_THE_SP.MAU_SAC.TenMau}" Width="90"/>
                                <DataGridTextColumn Header="SKU" Binding="{Binding BIEN_THE_SP.SKU}" Width="120"/>
                                <DataGridTextColumn Header="Số lượng tồn" Binding="{Binding SoLuongTon}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="📋 Phiếu nhập" FontSize="14">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Lịch sử phiếu nhập" FontSize="14" FontWeight="SemiBold" Foreground="#FF1E2A38" Margin="0,0,0,12"/>

                            <DataGrid Grid.Row="1" x:Name="dgPhieuNhap" AutoGenerateColumns="False" IsReadOnly="True"
                                      ItemsSource="{Binding ListPhieuNhap}" CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" BorderThickness="1" BorderBrush="#FFE0E0E0" RowHeight="40" FontSize="13">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã PN" Binding="{Binding MaPN}" Width="110"/>
                                    <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhap, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140"/>
                                    <DataGridTextColumn Header="Kho nhập" Binding="{Binding KHO.TenKho}" Width="*"/>
                                    <DataGridTextColumn Header="Nhà Sản Xuất" Binding="{Binding NHA_SAN_XUAT.TenNSX}" Width="150"/>

                                    <DataGridTextColumn Header="Tổng SL" Binding="{Binding TongSoLuong}" Width="80"/>
                                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat='{}{0:N0} ₫'}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Border Grid.Column="2" Background="#FFF8F9FA" CornerRadius="10" Padding="16" BorderBrush="#FFEAEAEA" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Tạo phiếu nhập mới" FontSize="14" FontWeight="SemiBold" Foreground="#FF1E2A38" Margin="0,0,0,16"/>

                                    <TextBlock Text="Mã phiếu nhập" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                                             BorderBrush="#FFE0E0E0" BorderThickness="1" IsReadOnly="True" Background="#FFEEEEEE"
                                             Text="{Binding MaPN, Mode=TwoWay}"/>

                                    <TextBlock Text="Kho nhập" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                                    <ComboBox Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                              DisplayMemberPath="TenKho" SelectedValuePath="MaKho"
                                              ItemsSource="{Binding ListKhoNhap}" SelectedValue="{Binding CboSelectedKhoNhap, Mode=TwoWay}"/>

                                    <TextBlock Text="Nhà sản xuất" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                                    <ComboBox Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                              DisplayMemberPath="TenNSX" SelectedValuePath="MaNSX"
                                              ItemsSource="{Binding ListNSXNhap}" SelectedValue="{Binding CboSelectedNSXNhap, Mode=TwoWay}"/>

                                    <TextBlock Text="Sản phẩm / Biến thể" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                                    <ComboBox Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                              SelectedValuePath="MaBienThe" ItemsSource="{Binding ListBienTheCombo}" 
                                              SelectedValue="{Binding CboSelectedBienThe, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding SAN_PHAM.TenSP}"/>
                                                    <TextBlock Text=" [Size: "/>
                                                    <TextBlock Text="{Binding SIZE_GIAY.TenSize}"/>
                                                    <TextBlock Text=" - Màu: "/>
                                                    <TextBlock Text="{Binding MAU_SAC.TenMau}"/>
                                                    <TextBlock Text="]"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Số lượng" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                                                     BorderBrush="#FFE0E0E0" BorderThickness="1"
                                                     Text="{Binding TxtSoLuongNhap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Giá nhập (₫)" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                                                     BorderBrush="#FFE0E0E0" BorderThickness="1"
                                                     Text="{Binding TxtGiaNhap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Button Content="+ Thêm vào lưới tạm" Height="34" Background="#FF2980B9" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="13" Margin="0,12,0,0"
                                            Command="{Binding AddToGridCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock Text="Chi tiết mặt hàng vừa thêm" Foreground="#FF555555" FontSize="12" Margin="0,16,0,4"/>
                                    <DataGrid x:Name="dgCtPhieuNhap" AutoGenerateColumns="False" IsReadOnly="True"
                                              ItemsSource="{Binding ListCtPhieuNhapTam}" CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column" BorderThickness="1" BorderBrush="#FFE0E0E0" RowHeight="36" FontSize="12" MaxHeight="160">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Sản phẩm / Biến thể" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                            <TextBlock Text="{Binding BIEN_THE_SP.SAN_PHAM.TenSP}"/>
                                                            <TextBlock Text=" ["/>
                                                            <TextBlock Text="{Binding BIEN_THE_SP.SIZE_GIAY.TenSize}"/>
                                                            <TextBlock Text="-"/>
                                                            <TextBlock Text="{Binding BIEN_THE_SP.MAU_SAC.TenMau}"/>
                                                            <TextBlock Text="]"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="50"/>
                                            <DataGridTextColumn Header="Giá" Binding="{Binding GiaNhap, StringFormat={}{0:N0} ₫}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Button Content="💾 Lưu phiếu nhập" Height="40" Background="#FF27AE60" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="13" FontWeight="Bold" Margin="0,12,0,0"
                                            Command="{Binding SavePhieuNhapCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="Hủy bỏ form" Height="32" Background="Transparent" Foreground="#FF9AA5B1"
                                            BorderThickness="0" Cursor="Hand" FontSize="13" Margin="0,6,0,0"
                                            Command="{Binding ClearFormCommand}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Page>