<Page x:Class="QuanLyShopGiay.Views.Pages.HoaDonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F5F5F5"
      Title="HoaDonPage">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Hóa đơn" FontSize="24" FontWeight="Bold" 
                       Foreground="#1E2A38" Margin="0,0,0,20"/>

            <TextBlock Text="Chọn sản phẩm" FontSize="15" FontWeight="Bold"
                       Foreground="#1E2A38" Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtTimKiem" Height="36" TextChanged="TxtTimKiem_TextChanged"
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                         BorderBrush="#E0E0E0"/>

                <ComboBox x:Name="cboLocLoai" Grid.Column="1"
                          ItemsSource="{Binding ListLoaiHang}"
                          DisplayMemberPath="TenLoai"
                          SelectedValuePath="MaLoai"
                          SelectedValue="{Binding SelectedMaLoai}"
                          SelectionChanged="CboLocLoai_SelectionChanged"
                          Height="36" Margin="12,0,0,0" FontSize="13" 
                          BorderBrush="#E0E0E0" Background="White"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500">
                <ItemsControl ItemsSource="{Binding ListSanPham}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6" Background="White" CornerRadius="8" BorderThickness="1" 
                                    BorderBrush="#E0E0E0" Cursor="Hand" Tag="{Binding}"
                                    MouseDown="CardSanPham_Click">
                                <StackPanel>
                                    <Image Source="{Binding AnhChinh}" Height="120" Stretch="Uniform" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TenSP}" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TenLoai}" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                                    <Grid>
                                        <TextBlock Text="{Binding GiaBan, StringFormat={}{0:N0} ₫}" FontSize="14" 
                                                   FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TotalSoLuongTon, StringFormat={}Còn: {0}}" FontSize="11" 
                                                   Foreground="#95A5A6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Giỏ hàng hiện tại" FontSize="16" FontWeight="Bold" Foreground="#1E2A38"/>
                        <TextBlock x:Name="lblXoaTatCa" Text="Xóa tất cả" FontSize="12" Foreground="#E74C3C" 
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="Hand"
                                   MouseDown="LblXoaTatCa_Click"/>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="250" Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding GioHang}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TenSP}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                <TextBlock Text="{Binding TenBienThe}" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,4"/>
                                                <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} ₫}" FontSize="12" Foreground="#E74C3C"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="-" Width="24" Height="24" Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                        Command="{Binding DataContext.GiamSoLuongCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>

                                                <TextBlock Text="{Binding SoLuong}" Width="30" TextAlignment="Center" 
                                                           VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>

                                                <Button Content="+" Width="24" Height="24" Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                        Command="{Binding DataContext.TangSoLuongCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>

                                                <TextBlock x:Name="btnXoaItem" Text="🗑" Margin="12,0,0,0" Foreground="#95A5A6" 
                                                           VerticalAlignment="Center" Cursor="Hand" FontSize="14" Tag="{Binding}"
                                                           MouseDown="BtnXoaItem_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="Thông tin đơn hàng" FontSize="14" FontWeight="Bold" Foreground="#1E2A38" Margin="0,0,0,12"/>

                    <TextBlock Text="Khách hàng" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ListKhachHang}"
                              SelectedItem="{Binding KhachHangDangChon}"
                              Height="32" Margin="0,0,0,12" FontSize="12" BorderBrush="#E0E0E0" Background="White">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="320">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TenKH}" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DiemTichLuy, StringFormat='({0} điểm)'}" Foreground="#27AE60" FontSize="11" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Phương thức thanh toán" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ListPhuongThuc}"
                              SelectedItem="{Binding PhuongThucDangChon}"
                              DisplayMemberPath="TenPT"
                              Height="32" Margin="0,0,0,12" FontSize="12" BorderBrush="#E0E0E0" Background="White"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    

                    <Separator Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Tổng thanh toán:" FontSize="13" FontWeight="Bold" Foreground="#1E2A38" VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#27AE60">
                            <Run Text="{Binding TongThanhToan, StringFormat={}{0:N0}}"/>
                            <Run Text=" ₫"/>
                        </TextBlock>
                    </Grid>

                    <Button Content="💳 THANH TOÁN" Height="44" 
                            Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ThanhToanCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>