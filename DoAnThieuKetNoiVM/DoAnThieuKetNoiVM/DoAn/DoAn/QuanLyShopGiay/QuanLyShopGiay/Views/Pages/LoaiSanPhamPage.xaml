<Page x:Class="QuanLyShopGiay.Views.Pages.LoaiSanPhamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="LoaiSanPhamPage">
    <Page.DataContext>
        <local:LoaiSanPhamViewModel/>
    </Page.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Thông Tin Loại Sản Phẩm" Grid.Column="0" Margin="0,0,10,0" Padding="10">
            <StackPanel>
                <TextBlock Text="Mã Loại * (Không sửa khi cập nhật):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox Text="{Binding MaLoai, UpdateSourceTrigger=PropertyChanged}" 
                         IsReadOnly="{Binding IsEditMode}"/>

                <TextBlock Text="Tên Loại Sản Phẩm *:" Margin="0,10,0,2" FontWeight="SemiBold"/>
                <TextBox Text="{Binding TenLoai, UpdateSourceTrigger=PropertyChanged}"/>

                <UniformGrid Columns="2" Margin="0,20,0,0">
                    <Button Content="THÊM MỚI" Command="{Binding AddCommand}" Height="35" Margin="2" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                    <Button Content="CẬP NHẬT" Command="{Binding EditCommand}" Height="35" Margin="2" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                    <Button Content="XÓA BỎ" Command="{Binding DeleteCommand}" Height="35" Margin="2" Background="#F44336" Foreground="White" FontWeight="Bold"/>
                    <Button Content="LÀM MỚI" Command="{Binding ResetCommand}" Height="35" Margin="2" Background="#757575" Foreground="White" FontWeight="Bold"/>
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Tìm kiếm tên loại:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}" VerticalContentAlignment="Center" Height="25"/>
            </StackPanel>

            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding ListLoaiSP}" 
                      SelectedItem="{Binding SelectedLoaiSP, UpdateSourceTrigger=PropertyChanged}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Loại Sản Phẩm" Binding="{Binding MaLoai}" Width="150"/>
                    <DataGridTextColumn Header="Tên Loại Sản Phẩm" Binding="{Binding TenLoai}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>