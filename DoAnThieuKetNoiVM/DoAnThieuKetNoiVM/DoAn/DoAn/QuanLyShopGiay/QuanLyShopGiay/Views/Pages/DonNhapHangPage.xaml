<Page x:Class="QuanLyShopGiay.Views.Pages.DonNhapHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="DonNhapHangPage">

    <Page.DataContext>
        <local:HoaDonNhapViewModel/>
    </Page.DataContext>

    <Grid Background="#F5F5F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">

                <!-- THÔNG TIN PHIẾU NHẬP -->
                <GroupBox Header="THÔNG TIN PHIẾU NHẬP" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Mã HĐ Nhập:" FontWeight="Bold"/>
                            <TextBox Text="{Binding MaPhieuNhap}" 
                                     IsEnabled="False" Height="35" Padding="10"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <Label Content="Nhà cung cấp:" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding DsNCC}" 
                                      SelectedValue="{Binding MaNCC}"
                                      DisplayMemberPath="TenNCC"
                                      SelectedValuePath="MaNCC"
                                      Height="35" Padding="10"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Ngày Nhập:" FontWeight="Bold"/>
                            <DatePicker SelectedDate="{Binding NgayNhap}" Height="35"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- CHI TIẾT PHIẾU NHẬP -->
                <GroupBox Header="CHI TIẾT PHIẾU NHẬP" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sản phẩm -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Sản phẩm:" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding DsSanPham}"
                                      SelectedValue="{Binding ChiTietInput.MaSP}"
                                      SelectedValuePath="MaSP"
                                      Height="35" Padding="5,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TenSP}" FontWeight="SemiBold"/>
                                            <TextBlock Text=" | Size: " Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding Size}" Foreground="#E74C3C"/>
                                            <TextBlock Text=" - " Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding MauSac}" Foreground="#2980B9"/>
                                            <TextBlock Text=" (Tồn: " Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding SoLuongTon}" Foreground="#27AE60"/>
                                            <TextBlock Text=")" Foreground="#7F8C8D"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Đơn giá -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                            <Label Content="Đơn giá nhập:" FontWeight="Bold"/>
                            <TextBox Text="{Binding ChiTietInput.GiaNhap, UpdateSourceTrigger=PropertyChanged}"
                                     Height="35" Padding="10"/>
                        </StackPanel>

                        <!-- Số lượng -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,0">
                            <Label Content="Số lượng:" FontWeight="Bold"/>
                            <TextBox Text="{Binding ChiTietInput.SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                     Height="35" Padding="10"/>
                        </StackPanel>

                        <!-- Nút Thêm SP -->
                        <Button Grid.Row="0" Grid.Column="3"
                                Content="Thêm SP"
                                Command="{Binding ThemSanPhamCommand}"
                                Background="#007BFF" Foreground="White"
                                Width="90" Height="35" VerticalAlignment="Bottom"/>

                        <!-- Nút Tạo Phiếu -->
                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                Content="➕ Tạo Phiếu Nhập Mới"
                                Command="{Binding TaoPhieuCommand}"
                                Background="#3E58E2" Foreground="White"
                                Height="38"/>
                    </Grid>
                </GroupBox>

                <!-- DATAGRID CHI TIẾT PHIẾU ĐANG TẠO -->
                <!-- FIX: chỉ bind DsChiTiet với các cột đúng của ChiTietPhieuNhapDisplay -->
                <GroupBox Header="CHI TIẾT PHIẾU ĐANG TẠO" Padding="15" Margin="0,0,0,15">
                    <DataGrid ItemsSource="{Binding DsChiTiet}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Height="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã SP" 
                                                Binding="{Binding MaSanPham}" Width="90"/>
                            <DataGridTextColumn Header="Tên sản phẩm" 
                                                Binding="{Binding TenSanPham}" Width="*"/>
                            <DataGridTextColumn Header="Số lượng" 
                                                Binding="{Binding SoLuong}" Width="80"/>
                            <DataGridTextColumn Header="Đơn giá" 
                                                Binding="{Binding DonGiaNhap, StringFormat={}{0:N0} ₫}" Width="120"/>
                            <DataGridTextColumn Header="Thành tiền" 
                                                Binding="{Binding ThanhTien, StringFormat={}{0:N0} ₫}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- LỊCH SỬ PHIẾU NHẬP -->
                <!-- FIX: bind DsHoaDonNhap với các cột đúng của HoaDonNhapDisplay -->
                <GroupBox Header="LỊCH SỬ PHIẾU NHẬP" Padding="15" Margin="0,0,0,15">
                    <DataGrid ItemsSource="{Binding DsHoaDonNhap}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Height="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ Nhập" 
                                                Binding="{Binding MaHDN}" Width="130"/>
                            <DataGridTextColumn Header="Nhà cung cấp" 
                                                Binding="{Binding TenNCC}" Width="*"/>
                            <DataGridTextColumn Header="Ngày nhập" 
                                                Binding="{Binding NgayNhap, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="150"/>
                            <DataGridTextColumn Header="Tổng tiền" 
                                                Binding="{Binding TongTien, StringFormat={}{0:N0} ₫}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- TỔNG TIỀN & NÚT -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                    <StackPanel Margin="0,0,20,0" VerticalAlignment="Center">
                        <Label Content="Tổng tiền phiếu:" FontWeight="Bold"/>
                        <TextBox Text="{Binding TongTien, StringFormat={}{0:N0} ₫}"
                                 IsEnabled="False" Width="160" Height="35" Padding="10"
                                 FontWeight="Bold" Foreground="#28A745"/>
                    </StackPanel>

                    <Button Content="💾 Lưu Phiếu"
                            Command="{Binding LuuPhieuCommand}"
                            Background="#28A745" Foreground="White"
                            Width="110" Height="35" VerticalAlignment="Bottom"/>

                    <Button Content="🚫 Hủy"
                            Command="{Binding HuyCommand}"
                            Background="#DC3545" Foreground="White"
                            Width="100" Height="35" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>