<Page x:Class="QuanLyShopGiay.Views.Pages.HoaDonBanHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="HoaDonBanHangPage">

    <Page.DataContext>
        <local:HoaDonBanHangViewModel/>
    </Page.DataContext>

    <Grid Background="#F5F5F5">
        <StackPanel Margin="20">

            <!-- THÔNG TIN HÓA ĐƠN -->
            <GroupBox Header="THÔNG TIN HÓA ĐƠN" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mã HĐ -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Mã HĐ:" FontWeight="Bold" FontSize="12"/>
                        <TextBox Text="{Binding MaHD}" IsEnabled="False" Height="35" Padding="10"/>
                    </StackPanel>

                    <!-- Khách Hàng -->
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <Label Content="Khách Hàng:" FontWeight="Bold" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding DsKhachHang}"
                                  SelectedValue="{Binding MaKH}"
                                  DisplayMemberPath="TenKH"
                                  SelectedValuePath="MaKH"
                                  Height="35" Padding="10"/>
                    </StackPanel>

                    <!-- Ngày Lập -->
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <Label Content="Ngày Lập:" FontWeight="Bold" FontSize="12"/>
                        <DatePicker SelectedDate="{Binding NgayLap}" Height="35" Padding="10"/>
                    </StackPanel>

                    <!-- Trạng Thái -->
                    <StackPanel Grid.Column="3">
                        <Label Content="Trạng Thái:" FontWeight="Bold" FontSize="12"/>
                        <TextBox Text="{Binding TrangThai}" IsEnabled="False" Height="35" Padding="10"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- CHI TIẾT HÓA ĐƠN -->
            <GroupBox Header="CHI TIẾT HÓA ĐƠN" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mã Sản Phẩm -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Mã Sản Phẩm:" FontWeight="Bold" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding DsSanPham}"
                                  SelectedItem="{Binding SelectedSanPham}"
                                  SelectedValuePath="MaSP"
                                  Height="35" Padding="10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MaSP, StringFormat={}{0} - {1}, 
                                               RelativeSource={RelativeSource AncestorType=ComboBoxItem}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Giá Bán -->
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <Label Content="Giá Bán:" FontWeight="Bold" FontSize="12"/>
                        <TextBox Text="{Binding ChiTietInput.GiaBan, StringFormat='0'}"
                                 IsEnabled="False" Height="35" Padding="10"/>
                    </StackPanel>

                    <!-- Số Lượng -->
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <Label Content="Số Lượng:" FontWeight="Bold" FontSize="12"/>
                        <TextBox Text="{Binding ChiTietInput.SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35" Padding="10"/>
                    </StackPanel>

                    <!-- Nút Thêm -->
                    <Button Grid.Column="3" Grid.Row="0"
                            Content="Thêm" 
                            Command="{Binding ThemSanPhamCommand}"
                            Background="#007BFF" Foreground="White" 
                            Width="80" Height="35" VerticalAlignment="Bottom"/>

                    <!-- Nút Tạo HĐ -->
                    <Button Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4"
                            Content="Tạo Hóa Đơn Bán"
                            Command="{Binding TaoHoaDonCommand}"
                            Background="#28A745" Foreground="White"
                            Height="35" Margin="0,10,0,0" FontWeight="Bold"/>
                </Grid>
            </GroupBox>

            <!-- DATAGRID CHI TIẾT -->
            <GroupBox Header="DANH SÁCH SẢN PHẨM BÁN" Padding="15" Margin="0,0,0,15">
                <DataGrid ItemsSource="{Binding DsChiTiet}"
                          AutoGenerateColumns="False"
                          Height="220">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="80"/>
                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSP}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60"/>
                        <DataGridTextColumn Header="Màu Sắc" Binding="{Binding MauSac}" Width="80"/>
                        <DataGridTextColumn Header="Số Lượng" Binding="{Binding SoLuong}" Width="70"/>
                        <DataGridTextColumn Header="Giá Bán" Binding="{Binding GiaBan, StringFormat='0'}" Width="100"/>
                        <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat='0'}" Width="100"/>
                        <DataGridTemplateColumn Header="Tùy Chọn" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa" 
                                            Command="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=DataContext.XoaChiTietCommand}"
                                            CommandParameter="{Binding}"
                                            Background="#DC3545" Foreground="White"
                                            Width="60" Height="25"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- TỔNG TIỀN & NÚT -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tổng Tiền -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,200,0">
                    <TextBlock Text="Cộng tiền hàng:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TongTien, StringFormat='0 đ'}"
                             IsEnabled="False" Width="200" Height="35" Padding="10" FontSize="14"/>
                </StackPanel>

                <!-- Nút Chức Năng -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" >
                    <Button Content="Sắc Nhân Thành Toán"
                            Command="{Binding ThanhToanCommand}"
                            Background="#28A745" Foreground="White"
                            Width="160" Height="40" FontWeight="Bold"/>

                    <Button Content="Hủy"
                            Command="{Binding HuyCommand}"
                            Background="#DC3545" Foreground="White"
                            Width="100" Height="40"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
