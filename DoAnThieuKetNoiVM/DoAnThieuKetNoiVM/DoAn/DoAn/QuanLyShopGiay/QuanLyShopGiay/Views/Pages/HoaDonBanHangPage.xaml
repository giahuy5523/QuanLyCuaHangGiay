<Page x:Class="QuanLyShopGiay.Views.Pages.HoaDonBanHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="HoaDonBanHangPage">

    <Page.DataContext>
        <local:HoaDonBanHangViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- ===== HÀNG TRÊN: Danh sách SP + Giỏ hàng ===== -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Hóa đơn" FontSize="24" FontWeight="Bold" 
                       Foreground="#1E2A38" Margin="0,0,0,20"/>

                    <TextBlock Text="Chọn sản phẩm" FontSize="15" FontWeight="Bold"
                       Foreground="#1E2A38" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtTimKiem" Height="36" 
                         TextChanged="TxtTimKiem_TextChanged"
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                         BorderBrush="#E0E0E0"/>

                        <!-- FIX 3: Thêm item "Tất cả" được xử lý từ ViewModel -->
                        <ComboBox x:Name="cboLocLoai" Grid.Column="1"
                          ItemsSource="{Binding ListLoaiHang}"
                          DisplayMemberPath="TenLoai"
                          SelectedValuePath="MaLoai"
                          SelectedValue="{Binding SelectedMaLoai}"
                          SelectionChanged="CboLocLoai_SelectionChanged"
                          Height="36" Margin="12,0,0,0" FontSize="13"
                          BorderBrush="#E0E0E0" Background="White"/>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500">
                        <ItemsControl ItemsSource="{Binding ListSanPham}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6" Background="White" CornerRadius="8" BorderThickness="1" 
                                    BorderBrush="#E0E0E0" Cursor="Hand" Tag="{Binding}"
                                    MouseDown="CardSanPham_Click">
                                        <StackPanel Margin="8">
                                            <Image Source="{Binding AnhChinh}" Height="120" 
                                           Stretch="Uniform" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding TenSP}" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis" 
                                               Margin="0,0,0,2"/>
                                            <!-- FIX: TenLoai không có trong SanPham entity, dùng MaLoai hoặc bỏ -->
                                            <TextBlock Text="{Binding MaLoai}" FontSize="11" 
                                               Foreground="#7F8C8D" Margin="0,0,0,6"/>
                                            <Grid>
                                                <TextBlock Text="{Binding GiaBan, StringFormat={}{0:N0} ₫}" 
                                                   FontSize="13" FontWeight="Bold" Foreground="#E74C3C" 
                                                   VerticalAlignment="Center"/>
                                                <!-- FIX: đúng tên cột DB là SoLuongTon, không phải TotalSoLuongTon -->
                                                <TextBlock Text="{Binding SoLuongTon, StringFormat='Còn: {0}'}" 
                                                   FontSize="11" Foreground="#95A5A6" 
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Giỏ hàng hiện tại" FontSize="16" FontWeight="Bold" 
                                   Foreground="#1E2A38"/>
                                <TextBlock Text="Xóa tất cả" FontSize="12" Foreground="#E74C3C" 
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                   Cursor="Hand" MouseDown="LblXoaTatCa_Click"/>
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="250" Margin="0,0,0,16">
                                <ItemsControl ItemsSource="{Binding GioHang}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <!-- FIX: "Te" → "TenSP" -->
                                                        <TextBlock Text="{Binding TenSP}" FontSize="13" 
                                                           FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                        <TextBlock Text="{Binding TenBienThe}" FontSize="11" 
                                                           Foreground="#7F8C8D" Margin="0,2,0,4"/>
                                                        <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} ₫}" 
                                                           FontSize="12" Foreground="#E74C3C"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" 
                                                        VerticalAlignment="Center">
                                                        <Button Content="-" Width="24" Height="24" 
                                                        Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                        Command="{Binding DataContext.GiamSoLuongCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                                        <TextBlock Text="{Binding SoLuong}" Width="30" 
                                                           TextAlignment="Center" VerticalAlignment="Center" 
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                        <Button Content="+" Width="24" Height="24" 
                                                        Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                        Command="{Binding DataContext.TangSoLuongCommand, 
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                                        <TextBlock Text="🗑" Margin="12,0,0,0" Foreground="#95A5A6" 
                                                           VerticalAlignment="Center" Cursor="Hand" 
                                                           FontSize="14" Tag="{Binding}"
                                                           MouseDown="BtnXoaItem_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Separator Margin="0,0,0,16"/>

                            <TextBlock Text="Thông tin đơn hàng" FontSize="14" FontWeight="Bold" 
                               Foreground="#1E2A38" Margin="0,0,0,12"/>

                            <!-- FIX 1: Bỏ ItemTemplate lỗi, dùng DisplayMemberPath đúng tên DB -->
                            <TextBlock Text="Khách hàng" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding ListKhachHang}"
                              SelectedItem="{Binding KhachHangDangChon}"
                              DisplayMemberPath="TenKhachHang"
                              Height="32" Margin="0,0,0,12" FontSize="12"
                              BorderBrush="#E0E0E0" Background="White"/>

                            <!-- FIX 2: DisplayMemberPath đúng tên cột DB -->
                            <TextBlock Text="Phương thức thanh toán" FontSize="12" 
                               Foreground="#7F8C8D" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding ListPhuongThuc}"
                              SelectedItem="{Binding PhuongThucDangChon}"
                              DisplayMemberPath="TenPhuongThuc"
                              Height="32" Margin="0,0,0,12" FontSize="12"
                              BorderBrush="#E0E0E0" Background="White"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                            <Separator Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Tổng thanh toán:" FontSize="13" FontWeight="Bold" 
                                   Foreground="#1E2A38" VerticalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="18" 
                                   FontWeight="Bold" Foreground="#27AE60">
                            <Run Text="{Binding TongThanhToan, StringFormat={}{0:N0}}"/>
                            <Run Text=" ₫"/>
                                </TextBlock>
                            </Grid>
                            <Button Content="💳 THANH TOÁN" Height="44"
                            Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding ThanhToanCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== LỊCH SỬ HÓA ĐƠN BÁN HÀNG ===== -->
            <Border Background="White" CornerRadius="8" Margin="0,24,0,0" Padding="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="LỊCH SỬ HÓA ĐƠN BÁN HÀNG" FontSize="13" FontWeight="Bold"
                       Foreground="#1E2A38" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding LichSuHoaDon}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderThickness="1"
                      BorderBrush="#E0E0E0"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontSize="13"
                      MaxHeight="260"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F5F6FA"/>
                                <Setter Property="Foreground" Value="#1E2A38"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHD}" Width="100"/>
                            <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                            <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLap, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="140"/>
                            <DataGridTextColumn Header="P.Thức TT" Binding="{Binding TenPhuongThuc}" Width="110"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat='{}{0:N0} ₫'}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>