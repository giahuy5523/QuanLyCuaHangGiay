<Page x:Class="QuanLyShopGiay.Views.Pages.SanPhamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels" 
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SanPhamPage"
      Background="White">

    <Page.DataContext>
        <local:SanPhamViewModel/>
    </Page.DataContext>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,16,0" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Danh sách sản phẩm" FontSize="15" FontWeight="SemiBold" Foreground="#FF1E2A38" VerticalAlignment="Center"/>
                    <Button Content="+ Thêm mới" HorizontalAlignment="Right" Width="100" Height="32"
                            Background="#FF2980B9" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13"
                            Command="{Binding ThemMoiCommand}"
                            Visibility="{Binding CoQuyenChinhSua, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}" Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#FFE0E0E0" BorderThickness="1"/>
                </Grid>

                <DataGrid x:Name="dgSanPham" Grid.Row="2"
                          ItemsSource="{Binding DanhSachSP}"
                          SelectedItem="{Binding SelectedSP, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" RowHeight="40" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="80"/>
    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSP}" Width="*"/>
    <DataGridTextColumn Header="Loại" Binding="{Binding TenLoai}" Width="100"/>
    <DataGridTextColumn Header="NSX" Binding="{Binding TenNSX}" Width="80"/>
    
    <DataGridTextColumn Header="ĐVT" Binding="{Binding TenDVT}" Width="70"/>
    
    <DataGridTextColumn Header="Giá bán" Binding="{Binding GiaBan, StringFormat={}{0:N0} ₫}" Width="110"/>
    <DataGridTemplateColumn Header="Trạng thái" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✅ Đang bán"/>
                                                <Setter Property="Foreground" Value="#FF27AE60"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                        <Setter Property="Text" Value="🚫 Ngừng"/>
                                                        <Setter Property="Foreground" Value="#FFE74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{Binding TieuDeForm}" FontSize="15" FontWeight="SemiBold" Foreground="#FF1E2A38" Margin="0,0,0,20"/>

                    <TextBlock Text="Mã sản phẩm" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MaSP, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding MaSPReadOnly}" Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Tên sản phẩm" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding TenSP, UpdateSourceTrigger=PropertyChanged}" Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Loại hàng" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                    <ComboBox ItemsSource="{Binding DanhSachLoai}" SelectedValue="{Binding MaLoai}" DisplayMemberPath="TenLoai" SelectedValuePath="MaLoai" Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Nhà sản xuất" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                    <ComboBox ItemsSource="{Binding DanhSachNSX}" SelectedValue="{Binding MaNSX}" DisplayMemberPath="TenNSX" SelectedValuePath="MaNSX" Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Đơn vị tính" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                    <ComboBox ItemsSource="{Binding DanhSachDVT}" SelectedValue="{Binding MaDVT}" DisplayMemberPath="TenDVT" SelectedValuePath="MaDVT" Height="34" FontSize="13" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Giá bán (₫)" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding GiaBanText, UpdateSourceTrigger=PropertyChanged}" Height="34" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="{Binding TenNutLuu}" Height="36"
                                Background="#FF27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13"
                                Command="{Binding LuuCommand}" IsEnabled="{Binding CoQuyenChinhSua}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#FFCCCCCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Content="🗑 Xóa" Height="36"
                                Background="#FFE74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="13"
                                Command="{Binding XoaCommand}" IsEnabled="{Binding CoTheXoa}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#FFCCCCCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Button Content="Hủy" Height="32" Background="Transparent" Foreground="#FF9AA5B1" BorderThickness="0" Cursor="Hand" FontSize="13" Margin="0,8,0,0" Command="{Binding HuyCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>