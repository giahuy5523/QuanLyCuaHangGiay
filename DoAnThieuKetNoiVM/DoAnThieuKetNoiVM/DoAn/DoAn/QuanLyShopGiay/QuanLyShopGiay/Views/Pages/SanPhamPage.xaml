<Page x:Class="QuanLyShopGiay.Views.Pages.SanPhamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels" 
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="850"
      Title="SanPhamPage"
      Background="White">


    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Thông Tin Sản Phẩm" Grid.Column="0" Margin="0,0,10,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Mã Sản Phẩm *:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding MaSP, UpdateSourceTrigger=PropertyChanged}" 
                             IsReadOnly="{Binding IsEditMode}"/>

                    <TextBlock Text="Tên Sản Phẩm *:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TenSP, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Loại Sản Phẩm *:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding ListLoaiSP}" 
                              DisplayMemberPath="TenLoai" 
                              SelectedItem="{Binding SelectedLoai}" 
                              IsEditable="False"/>

                    <TextBlock Text="Nhà Cung Cấp *:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding ListNCC}" 
                              DisplayMemberPath="TenNCC" 
                              SelectedItem="{Binding SelectedNCC}" 
                              IsEditable="False"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Size:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Màu Sắc:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding MauSac, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Giá Nhập (đ):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding GiaNhap, UpdateSourceTrigger=PropertyChanged}" 
                             IsReadOnly="True" 
                             Background="#EEEEEE" />

                    <TextBlock Text="Giá Bán (đ):" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="DarkGreen"/>
                    <TextBox Text="{Binding GiaBan, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Số Lượng Tồn Kho:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SoLuongTon, UpdateSourceTrigger=PropertyChanged}"/>

                    <UniformGrid Columns="2" Margin="0,20,0,0">
                        <Button Content="THÊM MỚI" Command="{Binding AddCommand}" Height="35" Margin="2" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                        <Button Content="CẬP NHẬT (SỬA)" Command="{Binding EditCommand}" Height="35" Margin="2" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                        <Button Content="XÓA SẢN PHẨM" Command="{Binding DeleteCommand}" Height="35" Margin="2" Background="#F44336" Foreground="White" FontWeight="Bold"/>
                        <Button Content="LÀM MỚI FORM" Command="{Binding ResetCommand}" Height="35" Margin="2" Background="#757575" Foreground="White" FontWeight="Bold"/>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.Row="0">
                <TextBlock Text="Tìm kiếm tên sản phẩm:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox Width="280" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}" VerticalContentAlignment="Center" Height="25"/>
            </StackPanel>

            <DataGrid Grid.Row="1" Margin="0,0,0,10"
                      ItemsSource="{Binding ListSanPham}" 
                      SelectedItem="{Binding SelectedSanPham, UpdateSourceTrigger=PropertyChanged}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="70"/>
                    <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSP}" Width="*"/>
                    <DataGridTextColumn Header="Loại Sản Phẩm" Binding="{Binding LoaiSanPham.TenLoai}" Width="120"/>
                    <DataGridTextColumn Header="Nhà Cung Cấp" Binding="{Binding NhaCungCap.TenNCC}" Width="130"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="50"/>
                    <DataGridTextColumn Header="Màu Sắc" Binding="{Binding MauSac}" Width="70"/>
                    <DataGridTextColumn Header="Giá Nhập" Binding="{Binding GiaNhap, StringFormat={}{0:N0} đ}" Width="95"/>
                    <DataGridTextColumn Header="Giá Bán" Binding="{Binding GiaBan, StringFormat={}{0:N0} đ}" Width="95"/>
                    <DataGridTextColumn Header="Tồn Kho" Binding="{Binding SoLuongTon}" Width="65"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox Header="Lịch Sử Thay Đổi Giá Của Sản Phẩm Đang Chọn" Grid.Row="2" Padding="5">
                <DataGrid ItemsSource="{Binding ListLichSuGia}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          Background="White" 
                          GridLinesVisibility="Vertical"
                          VerticalGridLinesBrush="#D3D3D3"
                          HorizontalGridLinesBrush="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="75"/>

                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding SanPham.TenSP}" Width="*"/>

                        <DataGridTextColumn Header="Giá Cũ" Binding="{Binding GiaCu, StringFormat={}{0:N0} đ}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Setter Property="Margin" Value="0,0,5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Giá Mới" Binding="{Binding GiaMoi, StringFormat={}{0:N0} đ}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="Margin" Value="0,0,5,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Ngày áp dụng" Binding="{Binding NgayCapNhat, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Page>