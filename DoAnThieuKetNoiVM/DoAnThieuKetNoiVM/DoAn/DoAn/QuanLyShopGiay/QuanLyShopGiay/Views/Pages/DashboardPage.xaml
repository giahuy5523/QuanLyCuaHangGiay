<Page x:Class="QuanLyShopGiay.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DashboardPage"
      Background="#FFF0F2F5">
    <Page.DataContext>
        <local:DashboardViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- THẺ SỐ -->
            <TextBlock Text="Tổng quan hôm nay" FontSize="16"
                   FontWeight="SemiBold" Foreground="#FF1E2A38"
                   Margin="0,0,0,16"/>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">

                <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="💰 Doanh thu hôm nay" Foreground="#FF9AA5B1" FontSize="13"/>
                        <TextBlock Text="{Binding Revenue}" FontSize="22" FontWeight="Bold" Foreground="#FF27AE60" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🧾 Tổng đơn hàng" Foreground="#FF9AA5B1" FontSize="13"/>
                        <TextBlock Text="{Binding OrderCount}" FontSize="22" FontWeight="Bold" Foreground="#FF2980B9" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👟 Sản phẩm đang bán" Foreground="#FF9AA5B1" FontSize="13"/>
                        <TextBlock Text="{Binding ProductCount}" FontSize="22" FontWeight="Bold" Foreground="#FF8E44AD" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="⏳ Đơn đang xử lý" Foreground="#FF9AA5B1" FontSize="13"/>
                        <TextBlock Text="{Binding ProcessingCount}" FontSize="22" FontWeight="Bold" Foreground="#FFE67E22" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- DANH SÁCH HÓA ĐƠN GẦN NHẤT -->
            <Border Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10"
                                  ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Hóa đơn gần nhất" FontSize="15"
                           FontWeight="SemiBold" Foreground="#FF1E2A38"
                           Margin="0,0,0,12"/>
                    <DataGrid x:Name="dgHoaDon"
                          ItemsSource="{Binding RecentOrders}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          RowHeight="40"
                          FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHD}" Width="100"/>
                            <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKH}" Width="*"/>
                            <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} ₫}" Width="130"/>

                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
