<Page x:Class="QuanLyShopGiay.Views.Pages.KhachHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="KhachHangPage">
    <Page.DataContext>
        <local:KhachHangViewModel/>
    </Page.DataContext>

<Grid Margin="16">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,16">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ComboBox Width="130" Height="34" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,8,0">
                <ComboBoxItem Content="Sản phẩm"/>
                <ComboBoxItem Content="Khách hàng"/>
            </ComboBox>
            <TextBox Width="280" Height="34" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,8,0"
                     Tag="Nhập từ khóa cần tìm..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Tìm kiếm" Width="100" Height="34" Background="#FF1E2A38" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="👤 Tài khoản: " Foreground="#FF555555" FontSize="13"/>
            <TextBlock Text="tuanadmin" FontWeight="Bold" Foreground="#FF2980B9" FontSize="13" Margin="0,0,16,0"/>
            <TextBlock Text="Quyền: " Foreground="#FF555555" FontSize="13"/>
            <TextBlock Text="Quản lý" FontWeight="Bold" Foreground="#FF27AE60" FontSize="13"/>
        </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16" BorderBrush="#FFE0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#DDDDDD" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>         <ColumnDefinition Width="220"/>       </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>       <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <ColumnDefinition Width="*"/>      <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>   <ColumnDefinition Width="1.5*"/>    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>   <ColumnDefinition Width="*"/>      </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã khách:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF555555"/>
                <TextBox Grid.Row="0" Grid.Column="1" Height="32" VerticalContentAlignment="Center" Background="#FFF0F2F5" IsEnabled="False" Text="{Binding MaKH}"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Tên khách:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF555555"/>
                <TextBox Grid.Row="0" Grid.Column="4" Height="32" VerticalContentAlignment="Center" Padding="6,0" Text="{Binding TenKH, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="0" Grid.Column="6" Text="Điện thoại:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF555555"/>
                <TextBox Grid.Row="0" Grid.Column="7" Height="32" VerticalContentAlignment="Center" Padding="6,0" Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Địa chỉ:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF555555"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Height="32" VerticalContentAlignment="Center" Padding="6,0" Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="6" Text="Điểm / Hạng:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF555555"/>
                <Grid Grid.Row="2" Grid.Column="7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="#FFF0F2F5" IsEnabled="False" Text="{Binding DiemTichLuy, FallbackValue=0}"/>
                    <TextBox Grid.Column="1" Height="32" VerticalContentAlignment="Center" Margin="6,0,0,0" Background="#FFF0F2F5" IsEnabled="False" Text="{Binding HangThanhVien, FallbackValue='-'}"/>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Button Content="Thêm" Height="28" Margin="0,0,3,0" Background="#FF2980B9" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Command="{Binding AddCommand}"/>
                    <Button Content="Lưu" Height="28" Margin="1,0,1,0" Background="#FF27AE60" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Command="{Binding SaveCommand}"/>
                    <Button Content="Xóa" Height="28" Margin="3,0,0,0" Background="#FFE74C3C" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Command="{Binding DeleteCommand}"/>
                </UniformGrid>
                
                <Button Content="Lịch sử mua" Height="34" Background="#FF4F46E5" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Command="{Binding HistoryCommand}">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12" BorderBrush="#FFE0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#DDDDDD" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
        </Border.Effect>
        
        <DataGrid x:Name="dgKhachHang" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" BorderThickness="0" RowHeight="40" FontSize="13"
                  ItemsSource="{Binding ListKhachHang}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH}" Width="100"/>
                <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding TenKH}" Width="220"/>
                <DataGridTextColumn Header="Điện Thoại" Binding="{Binding SDT}" Width="160"/>
                <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" Width="*"/>
                <DataGridTextColumn Header="Điểm" Binding="{Binding DiemTichLuy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Border>
</Grid>

</Page>
