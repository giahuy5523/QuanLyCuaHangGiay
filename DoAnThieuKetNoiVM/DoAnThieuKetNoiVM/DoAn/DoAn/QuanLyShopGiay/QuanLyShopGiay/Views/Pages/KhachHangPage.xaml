<Page x:Class="QuanLyShopGiay.Views.Pages.KhachHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="KhachHangPage">
    <Page.DataContext>
        <local:KhachHangViewModel/>
    </Page.DataContext>

<Grid Margin="16">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,16">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ComboBox Width="130" Height="34" SelectedIndex="1" VerticalContentAlignment="Center" Margin="0,0,8,0">
                <ComboBoxItem Content="Sản phẩm"/>
                <ComboBoxItem Content="Khách hàng"/>
            </ComboBox>
            <TextBox Width="280" Height="34" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,8,0"
                     Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <Button Content="Tìm kiếm" Width="90" Height="34" Command="{Binding SearchCommand}"/>
        </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="16" Margin="0,0,0,16" BorderBrush="#FFE0E0E0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Column="0" Orientation="Horizontal">
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="Mã khách hàng" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBox Width="130" Height="32" VerticalContentAlignment="Center" Padding="6,0" IsReadOnly="True" Background="#FFEAEAEA"
                             Text="{Binding MaKhachHang, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="Tên khách hàng" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBox Width="180" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                             Text="{Binding TenKhachHang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="Điện thoại" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBox Width="140" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                             Text="{Binding DienThoai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="Điểm tích lũy" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBox Width="100" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                             Text="{Binding Diem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="Tổng chi tiêu" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                    <TextBlock Width="150" Height="32" VerticalAlignment="Center" Padding="0,6,0,0" FontWeight="SemiBold" Foreground="#FF2E7D32" FontSize="14"
                               Text="{Binding TongMuaText}"/>
                </StackPanel>
            </WrapPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,12">
                <Button Content="Thêm" Width="75" Height="32" Margin="0,0,8,0" Command="{Binding AddCommand}"/>
                <Button Content="Sửa" Width="75" Height="32" Margin="0,0,8,0" Command="{Binding EditCommand}"/>
                <Button Content="Xóa" Width="75" Height="32" Margin="0,0,8,0" Command="{Binding DeleteCommand}"/>
                <Button Content="Làm mới" Width="75" Height="32" Command="{Binding ClearCommand}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12" BorderBrush="#FFE0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#DDDDDD" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
        </Border.Effect>

        <DataGrid x:Name="dgKhachHang" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" BorderThickness="0" RowHeight="40" FontSize="13"
                  ItemsSource="{Binding ListKhachHang}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKhachHang}" Width="100"/>
                <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding TenKhachHang}" Width="220"/>
                <DataGridTextColumn Header="Điện Thoại" Binding="{Binding DienThoai}" Width="160"/>
                <DataGridTextColumn Header="Điểm Tích Lũy" Binding="{Binding Diem}" Width="120"/>
                <DataGridTextColumn Header="Hạng Thành Viên" Binding="{Binding HangThanhVien}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Border>
</Grid>

</Page>
