<Page x:Class="QuanLyShopGiay.Views.Pages.KhachHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="850" d:DesignWidth="900"
      Title="KhachHangPage">

    <Page.DataContext>
        <local:KhachHangViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: placeholder header -->
            <Grid Grid.Row="0" Margin="0,0,0,16"/>

            <!-- ROW 1: Form nhập liệu khách hàng -->
            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="16"
                    Margin="0,0,0,16" BorderBrush="#FFE0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Mã khách hàng" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox Width="130" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                                     IsReadOnly="True" Background="#FFEAEAEA"
                                     Text="{Binding MaKhachHang, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Tên khách hàng" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox Width="180" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                                     Text="{Binding TenKhachHang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Điện thoại" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox Width="140" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                                     Text="{Binding DienThoai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Điểm tích lũy" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBox Width="100" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                                     Text="{Binding Diem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Tổng chi tiêu" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <TextBlock Width="150" Height="32" VerticalAlignment="Center" Padding="0,6,0,0"
                                       FontWeight="SemiBold" Foreground="#FF2E7D32" FontSize="14"
                                       Text="{Binding TongMuaText}"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,12">
                        <Button Content="Thêm"   Width="75" Height="32" Margin="0,0,8,0" Command="{Binding AddCommand}"/>
                        <Button Content="Sửa"    Width="75" Height="32" Margin="0,0,8,0" Command="{Binding EditCommand}"/>
                        <Button Content="Xóa"    Width="75" Height="32" Margin="0,0,8,0" Command="{Binding DeleteCommand}"/>
                        <Button Content="Làm mới" Width="75" Height="32" Command="{Binding ClearCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ROW 2: Danh sách khách hàng -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12"
                    BorderBrush="#FFE0E0E0" BorderThickness="1" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
                </Border.Effect>

                <DataGrid x:Name="dgKhachHang" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" BorderThickness="0" RowHeight="40" FontSize="13"
                          MaxHeight="260"
                          ItemsSource="{Binding ListKhachHang}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH"          Binding="{Binding MaKhachHang}"  Width="100"/>
                        <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding TenKhachHang}" Width="220"/>
                        <DataGridTextColumn Header="Điện Thoại"     Binding="{Binding DienThoai}"    Width="160"/>
                        <DataGridTextColumn Header="Điểm Tích Lũy"  Binding="{Binding Diem}"         Width="120"/>
                        <DataGridTextColumn Header="Hạng Thành Viên" Binding="{Binding HangThanhVien}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- ROW 3: LỊCH SỬ PHIẾU NHẬP -->
            <GroupBox Grid.Row="3" Margin="0,0,0,16">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦 LỊCH SỬ PHIẾU NHẬP KHO" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <Border Background="#3E58E2" CornerRadius="10" Padding="6,2" Margin="10,0,0,0">
                            <TextBlock Text="{Binding SoPhieuNhap, StringFormat={}{0} phiếu}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </GroupBox.Header>

                <StackPanel Margin="0,4,0,0">

                    <!-- Thanh lọc -->
                    <Border Background="#F0F4FF" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                            BorderBrush="#C5D0F5" BorderThickness="1">
                        <WrapPanel Orientation="Horizontal">

                            <!-- Tìm kiếm -->
                            <StackPanel Margin="0,0,16,6">
                                <TextBlock Text="Tìm kiếm (mã / NCC / nhân viên)" FontSize="11"
                                           Foreground="#555" Margin="0,0,0,3"/>
                                <TextBox Width="220" Height="30" VerticalContentAlignment="Center" Padding="6,0"
                                         Text="{Binding SearchPhieuNhap, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- Từ ngày -->
                            <StackPanel Margin="0,0,16,6">
                                <TextBlock Text="Từ ngày" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding TuNgayFilter}" Width="140" Height="30"/>
                            </StackPanel>

                            <!-- Đến ngày -->
                            <StackPanel Margin="0,0,16,6">
                                <TextBlock Text="Đến ngày" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding DenNgayFilter}" Width="140" Height="30"/>
                            </StackPanel>

                            <!-- Nút lọc -->
                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,8,6">
                                <Button Content="🔍 Lọc" Width="80" Height="30"
                                        Background="#3E58E2" Foreground="White"
                                        Command="{Binding SearchPhieuNhapCommand}"/>
                            </StackPanel>

                            <!-- Nút reset -->
                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,6">
                                <Button Content="↺ Đặt lại" Width="85" Height="30"
                                        Background="#6C757D" Foreground="White"
                                        Command="{Binding ResetPhieuNhapCommand}"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- Thống kê tổng -->
                    <Border Background="#EEF2FF" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                            BorderBrush="#C5D0F5" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tổng giá trị nhập kho:" FontWeight="SemiBold"
                                       Foreground="#3E58E2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding TongTienNhapText}" FontWeight="Bold" FontSize="15"
                                       Foreground="#28A745" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid lịch sử phiếu nhập -->
                    <DataGrid ItemsSource="{Binding LichSuPhieuNhap}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MaxHeight="220"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="38"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HĐ Nhập"
                                                Binding="{Binding MaHDN}" Width="140"/>
                            <DataGridTextColumn Header="Nhà cung cấp"
                                                Binding="{Binding TenNCC}" Width="*"/>
                            <DataGridTextColumn Header="Nhân viên lập"
                                                Binding="{Binding TenNhanVien}" Width="150"/>
                            <DataGridTextColumn Header="Ngày nhập"
                                                Binding="{Binding NgayNhap, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="160"/>
                            <DataGridTextColumn Header="Tổng tiền"
                                                Binding="{Binding TongTien, StringFormat={}{0:N0} ₫}" Width="130"/>
                        </DataGrid.Columns>

                        <!-- Style dòng: tô màu xen kẽ -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F5F7FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

        </Grid>
    </ScrollViewer>
</Page>
