<Page x:Class="QuanLyShopGiay.Views.Pages.NhaCungCapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d"
      Title="NhaCungCapPage" Height="600" Width="800">
	<Page.DataContext>
		<local:NhaCungCapViewModel/>
	</Page.DataContext>

	<Grid Margin="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
'

		<!-- HEADER: Tìm kiếm + Thông tin tài khoản (binding từ ViewModel) -->
		<Grid Grid.Row="0" Margin="0,0,0,20">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<ComboBox Width="130" Height="36" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,8,0">
					<ComboBoxItem Content="Nhà cung cấp"/>
					<ComboBoxItem Content="Sản phẩm"/>
				</ComboBox>
				<TextBox Width="260" Height="36" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,8,0"
                         Tag="Tìm kiếm tên, SĐT nhà cung cấp..."
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
			</StackPanel>

			<!-- FIX: Binding TenTaiKhoan và TenVaiTro từ ViewModel thay vì hardcode -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
				<TextBlock Text="👤 Tài khoản: " Foreground="#FF555555" FontSize="13"/>
				<TextBlock Text="{Binding TenTaiKhoan}" FontWeight="Bold" Foreground="#FF2980B9" FontSize="13" Margin="0,0,16,0"/>
				<TextBlock Text="Quyền: " Foreground="#FF555555" FontSize="13"/>
				<TextBlock Text="{Binding TenVaiTro}" FontWeight="Bold" Foreground="#FF27AE60" FontSize="13"/>
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="310"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- FORM NHẬP LIỆU -->
			<Border Grid.Column="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,16,0"
                    BorderBrush="#FFE0E0E0" BorderThickness="1" VerticalAlignment="Top">
				<Border.Effect>
					<DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
				</Border.Effect>

				<StackPanel>
					<TextBlock Text="QUẢN LÝ NHÀ CUNG CẤP" FontSize="15" FontWeight="Bold"
                               Foreground="#FF1E2A38" Margin="0,0,0,16" HorizontalAlignment="Center"/>

					<TextBlock Text="Mã Nhà Cung Cấp:" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
					<TextBox Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                             IsEnabled="{Binding IsMaNCCEnabled}"
                             Text="{Binding MaNCC, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock Text="Tên Nhà Cung Cấp (*):" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
					<TextBox Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                             Text="{Binding TenNCC, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock Text="Số Điện Thoại (10-15 số):" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
					<TextBox Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                             Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"/>

					<TextBlock Text="Địa Chỉ:" Foreground="#FF555555" FontSize="12" Margin="0,12,0,4"/>
					<TextBox Height="50" Padding="10,6" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                             Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"/>

					<Grid Margin="0,20,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="6"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="6"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0" Content="Thêm" Height="36"
                                Background="#FF1E2A38" Foreground="White" FontWeight="SemiBold"
                                Command="{Binding AddCommand}"/>
						<Button Grid.Column="2" Content="Lưu" Height="36"
                                Background="#FF27AE60" Foreground="White" FontWeight="SemiBold"
                                Command="{Binding SaveCommand}"/>
						<Button Grid.Column="4" Content="Xóa" Height="36"
                                Background="#FFEF4444" Foreground="White" FontWeight="SemiBold"
                                Command="{Binding DeleteCommand}"/>
					</Grid>

					<Button Content="🔄 Làm Mới Biểu Mẫu" Height="34" Margin="0,8,0,0"
                            Background="#FF9AA5B1" Foreground="White" FontWeight="SemiBold"
                            Command="{Binding ClearCommand}"/>
				</StackPanel>
			</Border>

			<!-- DANH SÁCH -->
			<Border Grid.Column="1" Background="White" CornerRadius="12" Padding="16"
                    BorderBrush="#FFE0E0E0" BorderThickness="1">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0" Text="Danh Sách Nhà Cung Cấp Hợp Tác"
                               FontSize="14" FontWeight="SemiBold" Foreground="#FF555555" Margin="4,0,0,12"/>

					<DataGrid Grid.Row="1" x:Name="dgNhaCungCap" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" BorderThickness="0" RowHeight="42" FontSize="13"
                              ItemsSource="{Binding ListNhaCungCap}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Mã NCC"           Binding="{Binding MaNCC}"  Width="90"/>
							<DataGridTextColumn Header="Tên Nhà Cung Cấp" Binding="{Binding TenNCC}" Width="230"/>
							<DataGridTextColumn Header="Địa Chỉ"          Binding="{Binding DiaChi}" Width="*"/>
							<DataGridTextColumn Header="Số Điện Thoại"    Binding="{Binding SDT}"    Width="130"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Page>
