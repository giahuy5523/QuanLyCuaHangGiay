<Window x:Class="QuanLyShopGiay.Views.Pages.NhaCungCapPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NhaCungCapPage" Height="600" Width="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox Width="130" Height="36" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,8,0">
                    <ComboBoxItem Content="Nhà cung cấp"/>
                    <ComboBoxItem Content="Sản phẩm"/>
                </ComboBox>
                <TextBox Width="260" Height="36" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,8,0"
                     Tag="Tìm kiếm tên, SĐT nhà cung cấp..." 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Tìm kiếm" Width="90" Height="36" Background="#FF1E2A38" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="👤 Tài khoản: " Foreground="#FF555555" FontSize="13"/>
                <TextBlock Text="admin" FontWeight="Bold" Foreground="#FF2980B9" FontSize="13" Margin="0,0,16,0"/>
                <TextBlock Text="Quyền: " Foreground="#FF555555" FontSize="13"/>
                <TextBlock Text="Quản lý" FontWeight="Bold" Foreground="#FF27AE60" FontSize="13"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,20,0" BorderBrush="#FFE0E0E0" BorderThickness="1" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="QUẢN LÝ NHÀ CUNG CẤP" FontSize="16" FontWeight="Bold" Foreground="#FF1E2A38" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <TextBlock Text="Mã Nhà Cung Cấp:" Foreground="#FF555555" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMaNCC" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" 
                         Background="#FFF0F2F5" IsEnabled="False" BorderThickness="1" BorderBrush="#FFE0E0E0"
                         Text="{Binding MaNCC}"/>

                    <TextBlock Text="Tên Nhà Cung Cấp (*):" Foreground="#FF555555" FontSize="12" Margin="0,14,0,4"/>
                    <TextBox x:Name="txtTenNCC" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" 
                         BorderThickness="1" BorderBrush="#FFE0E0E0"
                         Text="{Binding TenNCC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Số Điện Thoại (Bắt buộc 10-11 số):" Foreground="#FF555555" FontSize="12" Margin="0,14,0,4"/>
                    <TextBox x:Name="txtSDT" Height="36" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" 
                         BorderThickness="1" BorderBrush="#FFE0E0E0"
                         Text="{Binding SDT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Địa Chỉ:" Foreground="#FF555555" FontSize="12" Margin="0,14,0,4"/>
                    <TextBox x:Name="txtDiaChi" Height="60" Padding="10,6" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                         BorderThickness="1" BorderBrush="#FFE0E0E0"
                         Text="{Binding DiaChi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="➕ Thêm Mới" Height="38" Background="#FF1E2A38" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Command="{Binding AddCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="2" Content="💾 Lưu lại" Height="38" Background="#FF27AE60" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Command="{Binding SaveCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="4" Content="🗑️ Xóa" Height="38" Background="#FFE74C3C" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Command="{Binding DeleteCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Button Content="🔄 Làm Mới Trường Nhập" Height="34" Margin="0,8,0,0" Background="#FF9AA5B1" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Command="{Binding ClearCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="16" BorderBrush="#FFE0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Danh Sách Nhà Cung Cấp Đang Hợp Tác" FontSize="14" FontWeight="SemiBold" Foreground="#FF555555" Margin="4,0,0,12"/>

                    <DataGrid Grid.Row="1" x:Name="dgNhaCungCap" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column" 
                          BorderThickness="0" RowHeight="42" FontSize="13"
                          ItemsSource="{Binding ListNhaCungCap}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã NCC" Binding="{Binding MaNCC}" Width="90"/>
                            <DataGridTextColumn Header="Tên Nhà Cung Cấp" Binding="{Binding TenNCC}" Width="250"/>
                            <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" Width="*"/>
                            <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding SDT}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
