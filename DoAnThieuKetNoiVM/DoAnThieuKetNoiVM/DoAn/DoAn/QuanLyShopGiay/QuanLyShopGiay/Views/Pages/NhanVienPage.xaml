<Page x:Class="QuanLyShopGiay.Views.Pages.NhanVienPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      xmlns:helpers="clr-namespace:QuanLyShopGiay.Helpers"
      mc:Ignorable="d"
      d:DesignHeight="580" d:DesignWidth="860"
      Title="NhanVienPage"
      Background="#FFF0F2F5">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <local:NhanVienViewModel/>
    </Page.DataContext>
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12"
                Margin="0,0,14,0" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.35"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Danh sách nhân viên" FontSize="15"
                               FontWeight="SemiBold" Foreground="#FF1E2A38" VerticalAlignment="Center"/>

                    <Button Content="+ Thêm mới"
                            HorizontalAlignment="Right" Width="100" Height="32"
                            Background="#FF2980B9" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Command="{Binding ThemMoiCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="borderThem" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="borderThem" Property="Background" Value="#FFCCCCCC"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="borderThem" Property="Background" Value="#FF1C6EA4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="Hint" TileMode="None" Stretch="None" AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="🔍 Tìm theo mã, tên, SĐT..." Foreground="#FFAAAAAA" FontSize="13" Margin="10,0,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource Hint}"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DanhSachNV}"
                          SelectedItem="{Binding SelectedNV, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#FFE8E8E8"
                          HeadersVisibility="Column"
                          BorderThickness="1" BorderBrush="#FFE0E0E0"
                          RowHeight="36" FontSize="12"
                          AlternatingRowBackground="#FAFAFA"
                          SelectionMode="Single">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF1E2A38"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,7"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFD6EAF8"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEBF5FB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV"      Binding="{Binding MaNhanVien}"  Width="80"/>
                        <DataGridTextColumn Header="Họ tên"     Binding="{Binding TenNhanVien}" Width="*"/>
                        <DataGridTextColumn Header="Giới tính"  Binding="{Binding GioiTinh}"   Width="75"/>
                        <DataGridTextColumn Header="Ngày sinh"  Binding="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}" Width="95"/>
                        <DataGridTextColumn Header="SĐT"        Binding="{Binding SoDienThoai}" Width="105"/>
                        <DataGridTextColumn Header="Tài khoản"  Binding="{Binding TenDangNhap}" Width="100"/>
                        <DataGridTextColumn Header="Quyền"      Binding="{Binding Quyen}"        Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.35"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{Binding TieuDeForm}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#FF1E2A38" Margin="0,0,0,16"/>

                    <TextBlock Text="Mã nhân viên *"  FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MaNV, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding MaNVReadOnly}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="IsReadOnly" Value="True">
                                        <Setter Property="Background" Value="#FFF5F5F5"/>
                                        <Setter Property="Foreground" Value="#FF888888"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Họ và tên *" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding TenNV, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Giới tính" Foreground="#FF555555" FontSize="12" Margin="0,10,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Nam" Margin="0,0,20,0" FontSize="13"
                                     IsChecked="{Binding GioiTinh, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Nam, Mode=TwoWay}"/>
                        <RadioButton Content="Nữ" FontSize="13"
                                     IsChecked="{Binding GioiTinh, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Nữ, Mode=TwoWay}"/>
                    </StackPanel>

                    <TextBlock Text="Ngày sinh" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <DatePicker SelectedDate="{Binding NgaySinh}"
                                Height="34" FontSize="13"
                                BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Số điện thoại" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Địa chỉ" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Tên đăng nhập *" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0" FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Foreground="#FF555555" FontSize="12" Margin="0,10,0,4">
                        <Run Text="Mật khẩu"/>
                        <Run Text=" (bỏ trống = giữ cũ)" Foreground="#FF9AA5B1" FontSize="11"/>
                    </TextBlock>
                    <PasswordBox x:Name="PwdBox"
                                 helpers:PasswordBoxHelper.BindPassword="True"
                                 helpers:PasswordBoxHelper.BoundPassword="{Binding MatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Padding="10,4" FontSize="13"
                                 BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <TextBlock Text="Cấp quyền" Foreground="#FF555555" FontSize="12" Margin="0,10,0,4"/>
                    <ComboBox ItemsSource="{Binding QuyenList}"
                              SelectedItem="{Binding Quyen}"
                              Height="34" Padding="8,4" FontSize="13"
                              BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{Binding TenNutLuu}"
                                Height="36" Background="#FF27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                Command="{Binding LuuCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#FFCCCCCC"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF1E8449"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2"
                                Content="🗑️ Xóa nhân viên"
                                Height="36" Background="#FFE74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                Command="{Binding XoaCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border2"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border2" Property="Background" Value="#FFCCCCCC"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border2" Property="Background" Value="#FFC0392B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Button Content="Hủy bỏ" Height="32"
                            Background="Transparent" Foreground="#FF9AA5B1"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Margin="0,8,0,0"
                            Command="{Binding HuyCommand}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>