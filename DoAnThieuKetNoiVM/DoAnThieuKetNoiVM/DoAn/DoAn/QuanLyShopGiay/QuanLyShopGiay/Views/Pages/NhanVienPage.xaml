<Page x:Class="QuanLyShopGiay.Views.Pages.NhanVienPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="NhanVienPage"
      Background="White">
    <!--<Page.DataContext>
        <local:NhanVienViewModel/>
    </Page.DataContext>-->
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- CỘT TRÁI: DANH SÁCH -->
        <Border Grid.Column="0" Background="White" CornerRadius="12"
                Margin="0,0,16,0" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề + nút thêm mới -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Danh sách nhân viên" FontSize="15"
                               FontWeight="SemiBold" Foreground="#FF1E2A38"
                               VerticalAlignment="Center"/>
                    <!-- COMMAND: ThemMoiCommand | PHÂN QUYỀN: chỉ Admin -->
                    <Button x:Name="btnThemMoi" Content="+ Thêm mới"
                            HorizontalAlignment="Right" Width="100" Height="32"
                            Background="#FF2980B9" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Command="{Binding ThemMoiCommand}"
                            Visibility="{Binding CoQuyenChinhSua,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="8,4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Tìm kiếm realtime - BINDING: TuKhoa tự gọi LoadDanhSach -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <TextBox x:Name="txtTimKiem"
                             Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0"
                             FontSize="13" VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>
                </Grid>

                <!-- DataGrid - BINDING: ItemsSource = DanhSachNV (ObservableCollection) -->
                <DataGrid x:Name="dgNhanVien" 
                          Grid.Row="2"
                          ItemsSource="{Binding DanhSachNV}"
                          SelectedItem="{Binding SelectedNV, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          RowHeight="40"
                          FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV"    Binding="{Binding MaNV}"   Width="90"/>
                        <DataGridTextColumn Header="Họ tên"   Binding="{Binding HoTen}"  Width="*"/>
                        <DataGridTextColumn Header="Ngày sinh"
                                            Binding="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                        <DataGridTextColumn Header="Email"    Binding="{Binding Email}"  Width="160"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✅ Đang làm"/>
                                                <Setter Property="Foreground" Value="#FF27AE60"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                        <Setter Property="Text" Value="🚫 Nghỉ việc"/>
                                                        <Setter Property="Foreground" Value="#FFE74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- CỘT PHẢI: FORM THÊM/SỬA -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- BINDING: TieuDeForm tự đổi "Thêm mới" / "Chỉnh sửa" -->
                    <TextBlock Text="{Binding TieuDeForm}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#FF1E2A38" Margin="0,0,0,20"/>

                    <!-- Mã NV - BINDING: MaNV + IsReadOnly khi sửa -->
                    <TextBlock Text="Mã nhân viên" Foreground="#FF555555"
                               FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MaNV, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding MaNVReadOnly}"
                             Height="34" Padding="10,0"
                             FontSize="13" VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <!-- Họ tên - BINDING: HoTen -->
                    <TextBlock Text="Họ và tên" Foreground="#FF555555"
                               FontSize="12" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0"
                             FontSize="13" VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <!-- Ngày sinh - BINDING: NgaySinh -->
                    <TextBlock Text="Ngày sinh" Foreground="#FF555555"
                               FontSize="12" Margin="0,12,0,4"/>
                    <DatePicker SelectedDate="{Binding NgaySinh}"
                                Height="34" FontSize="13"
                                BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <!-- Email - BINDING: Email -->
                    <TextBlock Text="Email" Foreground="#FF555555"
                               FontSize="12" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Padding="10,0"
                             FontSize="13" VerticalContentAlignment="Center"
                             BorderBrush="#FFE0E0E0" BorderThickness="1"/>

                    <!-- Buttons Lưu / Xóa -->
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- COMMAND: LuuCommand | PHÂN QUYỀN: chỉ Admin -->
                        <Button Grid.Column="0" 
        Content="{Binding TenNutLuu}"  
        Height="36"
        Background="#FF27AE60" Foreground="White"
        BorderThickness="0" Cursor="Hand" FontSize="13"
        Command="{Binding LuuCommand}"
        IsEnabled="{Binding CoQuyenChinhSua}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="#FFCCCCCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- COMMAND: XoaCommand | PHÂN QUYỀN + IsEnabled: CoTheXoa -->
                        <Button Grid.Column="2" Content="🚫 Nghỉ việc" Height="36"
                                Background="#FFE74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"
                                Command="{Binding XoaCommand}"
                                IsEnabled="{Binding CoTheXoa}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- COMMAND: HuyCommand -->
                    <Button Content="Hủy" Height="32"
                            Background="Transparent" Foreground="#FF9AA5B1"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Margin="0,8,0,0"
                            Command="{Binding HuyCommand}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
