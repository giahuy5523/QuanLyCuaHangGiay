<UserControl x:Class="QuanLyShopGiay.Views.ucTimKiem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="450">
    <UserControl.DataContext>
        <local:ucTimKiemViewModel/>
    </UserControl.DataContext>
    <Border Background="White" CornerRadius="8" BorderBrush="#CCC" BorderThickness="1" Padding="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="cboLoaiTimKiem" Grid.Column="0" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,10,0">
                <ComboBoxItem Content="Sản phẩm"/>

            </ComboBox>

            <TextBox x:Name="txtTuKhoa" Grid.Column="1" VerticalContentAlignment="Center" 
               FontSize="14" Margin="0,0,10,0" Padding="5" />

            <Border Grid.Column="2" CornerRadius="5" Background="#3B5998">
                <Button x:Name="btnTimKiem" Content="Tìm kiếm"
                  Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
