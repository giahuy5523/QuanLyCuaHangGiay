<Window x:Class="QuanLyShopGiay.Views.StartApp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StartApp" Height="450" Width="800">

    <Grid Background="#FF0B1D35">


        <Image Source="/Anh/bg_start.jpg" Stretch="UniformToFill" />


        <Grid >


            <Button x:Name="BtnStart" Content="Nhấn vào đây để vào ứng dụng"
                    Width="350" Height="40"
                    FontWeight="Bold" FontSize="16"
                    Cursor="Hand"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,64" Click="BtnStart_Click"
                    />
        </Grid>
    </Grid>
</Window>