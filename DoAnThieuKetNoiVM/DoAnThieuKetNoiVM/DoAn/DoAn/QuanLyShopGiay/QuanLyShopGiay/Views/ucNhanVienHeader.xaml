<UserControl x:Class="QuanLyShopGiay.Views.ucNhanVienHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="300">
    <UserControl.DataContext>
        <local:NhanVienHeaderViewModel/>
    </UserControl.DataContext>

    <Border Background="#F5F6F9" CornerRadius="8" Padding="12,6" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="👤 " VerticalAlignment="Center" FontSize="13"/>
            <TextBlock Text="Tài khoản: " Foreground="#555" VerticalAlignment="Center" FontSize="13"/>
            <TextBlock x:Name="txtTenNhanVien" FontWeight="Bold" Foreground="#3B5998" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,0"/>

            <TextBlock Text="|" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,15,0"/>

            <TextBlock Text="Quyền: " Foreground="#555" VerticalAlignment="Center" FontSize="13"/>
            <TextBlock x:Name="txtQuyenNhanVien" FontWeight="Bold" Foreground="Green" VerticalAlignment="Center" FontSize="13"/>
        </StackPanel>
    </Border>
</UserControl>
