
<Window x:Class="QuanLyShopGiay.Views.SignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
        xmlns:helpers="clr-namespace:QuanLyShopGiay.Helpers"
        mc:Ignorable="d"
        x:Name="signUpWindow"
        Title="SignUp"
        Height="780" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <local:SignUpViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converter: string khác rỗng → Visible, rỗng → Collapsed -->
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- Converter: bool → Visibility (True=Visible, False=Collapsed) -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Converter: bool đảo ngược → Visibility (True=Collapsed, False=Visible) -->
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <!-- Style chung cho Label -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4,12,0,4"/>
        </Style>

        <!-- Style chung cho TextBox (dark theme) -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2980B9"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#FF222222"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style chung cho PasswordBox (dark theme) -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF2980B9"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho CheckBox (dark theme) -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4,4,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Style cho nút Đăng Ký -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2980B9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF1F6FA0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF185880"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF555555"/>
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background ảnh -->
        <Grid.Background>
            <ImageBrush ImageSource="/Anh/bg_SignUp.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Overlay gradient: FIX Offset trùng nhau -->
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#AA000000" Offset="0"/>
                    <GradientStop Color="#EE000000" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Card form -->
            <Border CornerRadius="16"
                    Background="#CC1A1A1A"
                    Padding="32,24"
                    MinWidth="420"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30"
                                      ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="680">
                    <StackPanel>

                        <!-- Tiêu đề -->
                        <TextBlock Text="Đăng Ký"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,24"/>

                        <!-- ── Tên đăng nhập ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="*" Foreground="#FFFF5252"
                                       FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Bottom" Margin="0,0,2,4"/>
                            <TextBlock Text="Tên đăng nhập" Style="{StaticResource LabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="txtTenDangNhap"
                                 Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50"/>

                        <!-- ── Email ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="*" Foreground="#FFFF5252"
                                       FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Bottom" Margin="0,0,2,4"/>
                            <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="txtEmail"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="100"/>

                        <!-- ── Họ và tên ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="*" Foreground="#FFFF5252"
                                       FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Bottom" Margin="0,0,2,4"/>
                            <TextBlock Text="Họ và tên" Style="{StaticResource LabelStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="txtHoTen"
                                 Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="100"/>

                        <!-- ── Mật khẩu ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="*" Foreground="#FFFF5252"
                                       FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Bottom" Margin="0,0,2,4"/>
                            <TextBlock Text="Mật khẩu" Style="{StaticResource LabelStyle}"/>
                        </StackPanel>

                        <!--
                            PasswordBox: hiện khi IsPasswordVisible = False
                            TextBox:     hiện khi IsPasswordVisible = True
                            Cả hai đều bind cùng property MatKhau qua PasswordBoxHelper
                        -->
                        <PasswordBox x:Name="pbMatKhau" Margin="5" helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"/>
                    



                        <!-- ── Xác nhận mật khẩu ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="*" Foreground="#FFFF5252"
                                       FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Bottom" Margin="0,0,2,4"/>
                            <TextBlock Text="Xác nhận mật khẩu" Style="{StaticResource LabelStyle}"/>
                        </StackPanel>

                        <PasswordBox x:Name="pbXacNhanMatKhau" Margin="5" helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"/>

                        

                        <!-- ── Mã nhân viên (không bắt buộc) ── -->
                        <TextBlock Text="Mã nhân viên (nếu có)"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtMaNV"
                                 Text="{Binding MaNV, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="20"/>

                        <!-- ── Thông báo lỗi ── -->
                        <TextBlock Text="{Binding ThongBaoLoi}"
                                   Foreground="#FFFF5252"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="4,10,4,0"
                                   Visibility="{Binding ThongBaoLoi,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>

                        <!-- ── Link đăng nhập ── -->
                        <TextBlock TextWrapping="Wrap"
                                   Text="Đã có tài khoản? Nhấn vào đây để đăng nhập."
                                   Foreground="#FFF4B62F"
                                   Margin="4,12,0,0"
                                   Cursor="Hand"
                                   FontSize="13"
                                   TextDecorations="Underline">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ChuyenDangNhapCommand}"
                                              CommandParameter="{Binding ElementName=signUpWindow}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>

                        <!-- ── Nút Đăng Ký ── -->
                        <Button Content="Đăng Ký"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding DangKyCommand}"
                                CommandParameter="{Binding ElementName=signUpWindow}"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,8"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
