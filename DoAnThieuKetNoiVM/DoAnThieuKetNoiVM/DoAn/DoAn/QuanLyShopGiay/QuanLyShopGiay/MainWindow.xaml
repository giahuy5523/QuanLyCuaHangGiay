<Window x:Class="QuanLyShopGiay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
       xmlns:views="clr-namespace:QuanLyShopGiay.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="900">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <Border Background="#FF1E2A38">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Background="#FF16202D" Padding="20,25">
                        <StackPanel>
                            <TextBlock Text="👟" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Shop Giày" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                            <TextBlock Text="{Binding HoTenNV, StringFormat='Xin chào, {0}'}" Foreground="#FF9AA5B1" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TenVaiTro}" Foreground="#FF6A8FA8" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Top" Margin="0,16,0,0">

                        <Button Content="📊  Dashboard"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavDashboardCommand}"/>

                        <Button Content="👟 Quản lý sản phẩm"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavSanPhamCommand}"/>

                        <Button Content="👟 Quản lý loại sản phẩm"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavLoaiSanPhamCommand}"/>

                        <Button Content="👤 Quản lý Khách Hàng"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavKhachHangCommand}"/>

                        <Button Content="🧾  Hóa đơn bán hàng"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavHoaDonBanHangCommand}"/>

                        <Button Content="📦  Hóa đơn nhập hàng"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavHoaDonNhapHangCommand}"/>

                        <Button Content="👤  Quản lý Nhân viên"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavNhanVienCommand}"/>

                        <Button Content="🏢  Nhà cung cấp"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavNhaCungCapCommand}"/>

                        <Button Content="🔑  Tài khoản"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavTaiKhoanCommand}"
                                Visibility="{Binding CoQuyenAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Padding="12,12">
                        <Button Content="🚪  Đăng xuất"
                                Style="{StaticResource SidebarButton}"
                                Background="#FF8B2020"
                                Command="{Binding DangXuatCommand}"/>
                    </Border>

                </DockPanel>
            </Border>
        </ScrollViewer>

        <Grid Grid.Column="1" Background="#FFF0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Column="1"
           Text="{Binding TieuDe}"
           FontSize="18" FontWeight="Bold"
           Foreground="#FF1E2A38" 
           VerticalAlignment="Center" 
           HorizontalAlignment="Left" 
           Margin="20,0,0,0"/>

                    <StackPanel Grid.Column="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center">

                        <TextBlock Text="{Binding NgayHienTai}"
                       Foreground="#FF9AA5B1" FontSize="13"
                       VerticalAlignment="Center" 
                       Margin="0,0,20,0"/>

                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="MainFrame" 
                   Grid.Row="1"
                   Margin="20" 
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>

    </Grid>
</Window>
