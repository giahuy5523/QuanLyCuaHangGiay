<Window x:Class="QuanLyShopGiay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyShopGiay.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="900">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Grid.Column="0" Background="#FF1E2A38">
                <DockPanel>

                    <!-- Logo / Tên shop -->
                    <Border DockPanel.Dock="Top" Background="#FF16202D" Padding="20,25">
                        <StackPanel>
                            <TextBlock Text="👟" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Shop Giày" Foreground="White"
                                       FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <!-- BINDING: tên + vai trò người đang đăng nhập -->
                            <TextBlock Text="{Binding HoTenNV, StringFormat='Xin chào, {0}'}"
                                       Foreground="#FF9AA5B1" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TenVaiTro}"
                                       Foreground="#FF6A8FA8" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Menu items -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,16,0,0">

                        <!-- Tất cả menu đều hiện với mọi người -->
                        <Button Content="📊  Dashboard"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavDashboardCommand}"/>

                        <Button Content="👟 Sản phẩm"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavSanPhamCommand}"/>
                        <Button Content="👤 Khách Hàng"
                                 Style="{StaticResource SidebarButton}"
                                 Command="{Binding NavKhachHangCommand}"/>                        
                        <Button Content="🧾  Hóa đơn"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavHoaDonCommand}"/>

                        <Button Content="📦  Kho hàng"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavKhoCommand}"/>

                        <Button Content="👤  Nhân viên"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavNhanVienCommand}"/>

                        <!-- CHỈ Admin mới thấy menu Tài khoản -->
                        <Button Content="🔑  Tài khoản"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavTaiKhoanCommand}"
                                Visibility="{Binding CoQuyenAdmin,
                                    Converter={StaticResource BoolToVisibilityConverter}}"/>

                    </StackPanel>

                    <!-- Đăng xuất -->
                    <Border DockPanel.Dock="Bottom" Padding="12,12">
                        <Button Content="🚪  Đăng xuất"
                                Style="{StaticResource SidebarButton}"
                                Background="#FF8B2020"
                                Command="{Binding DangXuatCommand}"/>
                    </Border>

                </DockPanel>
            </Border>
        </ScrollViewer>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Background="#FFF0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White"
                    BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <!-- BINDING: tiêu đề trang hiện tại -->
                    <TextBlock Text="{Binding TieuDe}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#FF1E2A38" VerticalAlignment="Center"/>
                    <!-- BINDING: ngày giờ -->
                    <TextBlock Text="{Binding NgayHienTai}"
                               Foreground="#FF9AA5B1" FontSize="13"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Frame x:Name="MainFrame" Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   />
        </Grid>
    </Grid>
</Window>
